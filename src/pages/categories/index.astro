---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const posts=(await getCollection('posts')).filter(p=>!p.data.draft);const by=posts.reduce((a,p)=>{const c=p.data.category||'General';(a[c] ||= []).push(p);return a},{});const slug=s=>s.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');
---
<BaseLayout title="Categories" description="Browse Smartcashflow guides by topic."><section class="container section--tight"><div class="eyebrow">Learning paths</div><h1 class="display" style="font-size:clamp(2.2rem,5vw,3.6rem);margin-top:12px">Categories</h1><div class="cards-3 mt-24">{Object.entries(by).map(([c,items])=><a href={`/category/${slug(c)}/`} class="card card--link" style="padding:24px"><span class="tag tag--brass">{items.length} guides</span><h2 class="h3" style="margin-top:12px">{c}</h2><p class="card__excerpt" style="margin-top:8px">Latest: {items[0].data.title}</p></a>)}</div></section></BaseLayout>

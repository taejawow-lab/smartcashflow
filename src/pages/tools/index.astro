---
import BaseLayout from '../../layouts/BaseLayout.astro';
const tools=[['emergency-fund','Emergency Fund Calculator','Size your safety net to your real costs and risk.','<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3 5 6v5c0 5 3 8 7 10 4-2 7-5 7-10V6l-7-3Z"/><path d="m9 12 2 2 4-5"/></svg>'],['retirement','Retirement Simulator','Project your savings into a future paycheck.','<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21V10"/><path d="M12 10c-4 0-6-2-7-6 4 0 7 2 7 6Z"/><path d="M12 13c5 0 7-3 8-7-5 0-8 3-8 7Z"/></svg>'],['cash-flow','Cash Flow Tracker','Give every dollar a job before the month begins.','<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 19V5"/><path d="M4 19h16"/><path d="m7 15 4-4 3 3 5-7"/></svg>'],['insurance','Insurance Needs Estimator','Estimate life insurance with DIME-style inputs.','<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12a9 9 0 0 1 18 0Z"/><path d="M12 12v7a2 2 0 0 0 4 0"/></svg>']];
---
<BaseLayout title="Tools" description="Four client-side calculators for emergency funds, retirement, cash flow, and insurance."><section class="hero-dark"><div class="container" style="position:relative;padding-block:clamp(56px,8vw,104px);text-align:center"><div class="eyebrow eyebrow--cream no-rule" style="justify-content:center;margin-bottom:18px">Calculators</div><h1 class="display" style="color:var(--paper)">Tools that turn advice into a <span class="serif-italic" style="color:var(--brass-300)">plan</span>.</h1><p class="lede" style="color:rgba(244,240,230,.8);margin:20px auto 0;max-width:58ch">All math runs in your browser. Nothing is sent off-device.</p></div></section><section class="section container"><div class="cards-2">{tools.map(([slug,name,desc,ico])=><a href={`/tools/${slug}/`} class="card card--link" style="padding:28px"><span style="width:56px;height:56px;border-radius:var(--r-md);display:grid;place-items:center;background:var(--green-900);color:var(--brass-300);margin-bottom:18px" set:html={ico}></span><span class="tag tag--brass">Calculator</span><h2 class="h3" style="margin-top:12px">{name}</h2><p class="card__excerpt" style="margin-top:8px">{desc}</p><span class="link-arrow mt-16">Open calculator <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg></span></a>)}</div></section></BaseLayout>

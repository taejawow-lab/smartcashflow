---
import BaseLayout from '../../layouts/BaseLayout.astro';
export function getStaticPaths(){return ['emergency-fund','retirement','cash-flow','insurance'].map(tool=>({params:{tool}}));}
const tool=Astro.params.tool;const data={'emergency-fund':['Emergency Fund Calculator','Size your safety net to your real costs and risk.','<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3 5 6v5c0 5 3 8 7 10 4-2 7-5 7-10V6l-7-3Z"/><path d="m9 12 2 2 4-5"/></svg>'],'retirement':['Retirement Simulator','Project a rough future nest egg from savings, return, and time.','<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21V10"/><path d="M12 10c-4 0-6-2-7-6 4 0 7 2 7 6Z"/><path d="M12 13c5 0 7-3 8-7-5 0-8 3-8 7Z"/></svg>'],'cash-flow':['Cash Flow Tracker','Give every dollar a job before the month begins.','<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 19V5"/><path d="M4 19h16"/><path d="m7 15 4-4 3 3 5-7"/></svg>'],'insurance':['Insurance Needs Estimator','Estimate life insurance needs using income, debts, mortgage, and education costs.','<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12a9 9 0 0 1 18 0Z"/><path d="M12 12v7a2 2 0 0 0 4 0"/></svg>']}[tool];
---
<BaseLayout title={data[0]} description={data[1]}><section class="hero-dark"><div class="container" style="position:relative;padding-block:clamp(40px,6vw,72px)"><nav class="row gap-8" style="font-size:.85rem;color:rgba(244,240,230,.6);margin-bottom:20px"><a href="/tools/">Tools</a><span>/</span><span style="color:var(--brass-300)">{data[0]}</span></nav><div class="row gap-16"><span style="width:56px;height:56px;border-radius:var(--r-md);display:grid;place-items:center;background:rgba(244,240,230,.08);border:1px solid var(--line-cream);color:var(--brass-300);flex:none" set:html={data[2]}></span><div><h1 class="h1" style="color:var(--paper)">{data[0]}</h1><p class="lede" style="color:rgba(244,240,230,.74);margin-top:6px;max-width:52ch">{data[1]}</p></div></div></div></section><section class="section--tight container" data-tool={tool}><div class="tool-layout"><div class="card" style="padding:clamp(22px,3vw,34px)"><form id="tool-form"></form></div><div class="result-card" id="tool-result"></div></div><p class="muted center" style="font-size:.82rem;margin-top:28px;max-width:650px;margin-inline:auto">These calculators are educational estimates, not individualized financial advice. Figures are illustrative and do not account for taxes, fees, or your full situation.</p></section><script is:inline>
const fmt=n=>'$'+Math.round(Number(n)||0).toLocaleString('en-US'),clamp=(v,l,h)=>Math.max(l,Math.min(h,v)),tool=document.querySelector('[data-tool]').dataset.tool,form=document.getElementById('tool-form'),out=document.getElementById('tool-result');
const money=(id,l,v)=>`<div style="margin-bottom:20px"><label class="eyebrow no-rule" for="${id}" style="margin-bottom:8px">${l}</label><div class="input-prefix"><span>$</span><input class="field-l" id="${id}" type="number" min="0" value="${v}"></div></div>`;
const range=(id,l,v,min,max,step=1)=>`<div style="margin-bottom:22px"><div class="row" style="justify-content:space-between;margin-bottom:8px"><label class="eyebrow no-rule" for="${id}">${l}</label><span class="figure-num" id="${id}-v">${v}</span></div><input id="${id}" type="range" min="${min}" max="${max}" step="${step}" value="${v}" style="width:100%;accent-color:var(--green-700)"></div>`;
const val=id=>Number(document.getElementById(id)?.value)||0,big=(l,v,s='')=>`<div style="margin-bottom:22px"><div class="eyebrow eyebrow--cream" style="margin-bottom:10px">${l}</div><div class="result-num">${v}</div>${s?`<p style="color:rgba(244,240,230,.7);margin-top:10px;font-size:.92rem">${s}</p>`:''}</div>`;function bind(fn){form.querySelectorAll('input').forEach(i=>i.addEventListener('input',fn));fn()}
if(tool==='emergency-fund'){form.innerHTML=`<h2 class="h3">Your situation</h2><p class="muted">Use essential monthly costs.</p>${money('expenses','Monthly essential expenses',3200)}${range('months','Months of buffer',6,3,12)}${money('current','Current emergency savings',4500)}${money('monthly','Monthly savings pace',500)}`;bind(()=>{document.getElementById('months-v').textContent=val('months');const target=val('expenses')*val('months'),gap=Math.max(0,target-val('current')),pct=target?clamp(val('current')/target*100,0,100):0;out.innerHTML=big('Your target fund',fmt(target),`${val('months')} months × ${fmt(val('expenses'))}`)+`<div class="progress-shell"><div class="progress-fill" style="width:${pct}%"></div></div><p style="color:rgba(244,240,230,.75);margin-top:12px">${Math.round(pct)}% funded · still to save ${fmt(gap)}</p>`})}
else if(tool==='retirement'){form.innerHTML=`<h2 class="h3">Savings engine</h2>${money('current','Current retirement savings',65000)}${money('monthly','Monthly contribution',750)}${range('years','Years to invest',25,1,45)}${range('return','Expected annual return %',6,1,10,.5)}`;bind(()=>{document.getElementById('years-v').textContent=val('years');document.getElementById('return-v').textContent=val('return')+'%';const r=val('return')/100/12,n=val('years')*12,f=val('current')*Math.pow(1+r,n)+val('monthly')*((Math.pow(1+r,n)-1)/(r||1));out.innerHTML=big('Projected balance',fmt(f),`${val('years')} years at ${val('return')}% annual return`)})}
else if(tool==='cash-flow'){form.innerHTML=`<h2 class="h3">Zero-based month</h2>${money('income','Monthly take-home income',6200)}${money('fixed','Fixed bills',2800)}${money('variable','Variable spending',1500)}${money('savings','Saving / debt payoff',1200)}${money('fun','Fun money',450)}`;bind(()=>{const assigned=val('fixed')+val('variable')+val('savings')+val('fun'),left=val('income')-assigned,pct=val('income')?clamp(assigned/val('income')*100,0,100):0;out.innerHTML=big(left>=0?'Unassigned dollars':'Over-assigned by',fmt(Math.abs(left)),left>=0?'Give this money a job.':'Trim a category or increase income assumptions.')+`<div class="progress-shell"><div class="progress-fill" style="width:${pct}%"></div></div>`})}
else{form.innerHTML=`<h2 class="h3">DIME inputs</h2>${money('debt','Debts and final expenses',25000)}${money('income','Annual income to replace',85000)}${range('years','Years of income support',10,1,30)}${money('mortgage','Mortgage balance',280000)}${money('education','Education costs',60000)}${money('assets','Existing coverage and assets',150000)}`;bind(()=>{document.getElementById('years-v').textContent=val('years');const need=val('debt')+val('income')*val('years')+val('mortgage')+val('education'),net=Math.max(0,need-val('assets'));out.innerHTML=big('Estimated coverage gap',fmt(net),`Gross need ${fmt(need)} minus existing resources ${fmt(val('assets'))}`)})}
</script></BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
const posts=(await getCollection('posts')).filter(p=>!p.data.draft).map(p=>({slug:p.slug,title:p.data.title,description:p.data.description,category:p.data.category,url:`/posts/${p.slug}/`}));
---
<BaseLayout title="Saved" description="Saved Smartcashflow guides stored locally in this browser."><section class="container section--tight"><div class="eyebrow">Saved locally</div><h1 class="display" style="font-size:clamp(2.2rem,5vw,3.6rem);margin-top:12px">Saved guides</h1><p class="lede" style="margin-top:12px;max-width:58ch">Bookmarks are stored only in your browser.</p><div id="saved-results" class="cards-3 mt-24" aria-live="polite"></div><script type="application/json" id="saved-index" set:html={JSON.stringify(posts)}/><script is:inline>const all=JSON.parse(document.getElementById('saved-index').textContent||'[]'),saved=JSON.parse(localStorage.getItem('scf_bookmarks_v1')||'[]'),items=all.filter(p=>saved.includes(p.slug)),root=document.getElementById('saved-results');root.innerHTML=items.length?items.map(i=>`<a href="${i.url}" class="card card--link" style="padding:24px"><span class="tag tag--brass">${i.category||'Guide'}</span><h2 class="h3" style="margin-top:12px">${i.title}</h2><p class="card__excerpt" style="margin-top:8px">${i.description||''}</p><span class="link-arrow mt-16">Read guide →</span></a>`).join(''):`<div class="card" style="padding:28px;grid-column:1/-1"><h2 class="h3">No saved guides yet.</h2><p class="muted">Use bookmark buttons to build a local reading list.</p><a class="btn btn--primary mt-16" href="/posts/">Browse guides</a></div>`</script></section></BaseLayout>

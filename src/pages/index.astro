---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
const posts=(await getCollection('posts')).filter(p=>!p.data.draft).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
const featured=posts[0]; const latest=posts.slice(0,3);
const cats=['Personal Finance','Emergency Funds','Insurance','Cash Flow','Retirement'];
const tools=[['emergency-fund','Emergency Fund Calculator','Size your safety net to real costs and risk.','<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3 5 6v5c0 5 3 8 7 10 4-2 7-5 7-10V6l-7-3Z"/><path d="m9 12 2 2 4-5"/></svg>'],['retirement','Retirement Simulator','Project savings into a future paycheck.','<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21V10"/><path d="M12 10c-4 0-6-2-7-6 4 0 7 2 7 6Z"/><path d="M12 13c5 0 7-3 8-7-5 0-8 3-8 7Z"/></svg>'],['cash-flow','Cash Flow Tracker','Give every dollar a job.','<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 19V5"/><path d="M4 19h16"/><path d="m7 15 4-4 3 3 5-7"/></svg>'],['insurance','Insurance Needs Estimator','Estimate life insurance needs.','<svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12a9 9 0 0 1 18 0Z"/><path d="M12 12v7a2 2 0 0 0 4 0"/></svg>']];
const slug=s=>s.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');
---
<BaseLayout title="Home" description="Trustworthy, jargon-free guidance on emergency funds, insurance, cash flow, and retirement."><section class="hero-dark"><div class="container" style="position:relative;padding-block:clamp(60px,9vw,120px)"><div class="hero-grid"><div><div class="eyebrow eyebrow--cream" style="margin-bottom:22px">Money, made calm</div><h1 class="display" style="color:var(--paper);max-width:15ch">Build a financial life that <span class="serif-italic" style="color:var(--brass-300)">holds steady</span>.</h1><p class="lede" style="color:rgba(244,240,230,.82);max-width:46ch;margin-top:22px">Trustworthy, jargon-free guidance on emergency funds, insurance, cash flow, and retirement — paired with calculators that turn advice into a plan.</p><div class="row wrap gap-12" style="margin-top:34px"><a href="/tools/" class="btn btn--brass btn--lg">Open the toolkit <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg></a><a href="/posts/" class="btn btn--on-dark btn--lg">Start with the basics</a></div><div class="row wrap gap-24" style="margin-top:40px"><div><div class="figure-num" style="font-size:1.7rem;color:var(--brass-300)">4</div><div style="font-size:.8rem;color:rgba(244,240,230,.6)">free calculators</div></div><div><div class="figure-num" style="font-size:1.7rem;color:var(--brass-300)">CFP®</div><div style="font-size:.8rem;color:rgba(244,240,230,.6)">reviewed guidance</div></div><div><div class="figure-num" style="font-size:1.7rem;color:var(--brass-300)">0</div><div style="font-size:.8rem;color:rgba(244,240,230,.6)">sales pitches</div></div></div></div>{featured&&<a href={`/posts/${featured.slug}/`} class="card card--link" style="background:rgba(244,240,230,.05);border-color:var(--line-cream)"><div class="card__media">{featured.data.heroImage?<img src={featured.data.heroImage} alt={featured.data.title}/>:<div class="swatch"><div class="swatch__grid"></div><div class="swatch__mark"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 19V5"/><path d="M4 19h16"/><path d="m7 15 4-4 3 3 5-7"/></svg></div></div>}<span class="tag tag--brass" style="position:absolute;top:16px;left:16px">Editor's pick</span></div><div class="card__body"><div class="eyebrow eyebrow--cream">{featured.data.category}</div><h3 class="h3" style="color:var(--paper)">{featured.data.title}</h3><p style="color:rgba(244,240,230,.72);margin:0">{featured.data.description}</p><span class="link-arrow" style="color:var(--brass-300)">Read the guide <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg></span></div></a>}</div></div></section><section class="section--tight container"><div class="cards-3"><div class="card" style="padding:22px"><div class="eyebrow">Trust</div><h3>Reviewed by planners</h3><p class="muted">Guides use official sources and practical household examples.</p></div><div class="card" style="padding:22px"><div class="eyebrow">No pitch</div><h3>No products, no pressure</h3><p class="muted">We do not need your numbers to sell you anything.</p></div><div class="card" style="padding:22px"><div class="eyebrow">Plain English</div><h3>Decisions over jargon</h3><p class="muted">Every page ends in a next step you can take.</p></div></div></section><section class="section--tight container"><div class="eyebrow" style="margin-bottom:12px">Where to begin</div><h2 class="h2" style="margin-bottom:32px">Five pillars of a steady financial life</h2><div class="cards-3">{cats.map(c=><a class="card card--link" style="padding:24px" href={`/category/${slug(c)}/`}><h3 class="card__title">{c}</h3><p class="card__excerpt">A curated learning path for {c.toLowerCase()} decisions.</p><span class="link-arrow mt-16">Open path <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg></span></a>)}</div></section><section class="section--tight container"><div class="eyebrow" style="margin-bottom:12px">Fresh from the desk</div><h2 class="h2" style="margin-bottom:32px">Latest guides</h2><div class="cards-3">{latest.map(p=><ArticleCard title={p.data.title} description={p.data.description} href={`/posts/${p.slug}/`} image={p.data.heroImage} category={p.data.category} pubDate={p.data.pubDate} slug={p.slug}/>)}</div></section><section class="section" style="background:var(--paper-2)"><div class="container"><div class="eyebrow" style="margin-bottom:12px">Tools, not just takes</div><h2 class="h2" style="margin-bottom:32px">Turn the advice into a plan</h2><div class="cards-2">{tools.map(([slug,name,desc,ico])=><a href={`/tools/${slug}/`} class="card card--link" style="padding:28px"><span style="width:56px;height:56px;border-radius:var(--r-md);display:grid;place-items:center;background:var(--green-900);color:var(--brass-300);margin-bottom:18px" set:html={ico}></span><h3 class="card__title">{name}</h3><p class="card__excerpt">{desc}</p><span class="link-arrow mt-16">Try it <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg></span></a>)}</div></div></section><section class="section--tight container"><div class="nl-strip"><div style="position:relative"><div class="eyebrow eyebrow--cream">The Steady State</div><h2 class="h2" style="color:var(--paper);margin-top:12px">One useful money idea, every Sunday.</h2><form class="nl-form" data-scf-newsletter><input class="field" type="email" name="email" placeholder="you@example.com" required/><button class="btn btn--brass" type="submit">Subscribe</button></form><p data-scf-newsletter-status style="color:rgba(244,240,230,.7);margin-top:10px"></p></div></div></section></BaseLayout>

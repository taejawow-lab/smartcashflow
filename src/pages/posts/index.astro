---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
const posts=(await getCollection('posts')).filter(p=>!p.data.draft).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
const categories=[...new Set(posts.map(p=>p.data.category).filter(Boolean))].sort();
---
<BaseLayout title="Guides" description={`Complete archive of ${posts.length} Smartcashflow guides.`}><section class="container section--tight"><div style="border-bottom:1px solid var(--line);padding-bottom:36px;margin-bottom:34px"><div class="eyebrow">Guides</div><h1 class="display" style="font-size:clamp(2.2rem,5vw,3.6rem);margin-top:12px">All guides</h1><p class="lede" style="margin-top:12px;max-width:58ch">Filter the full archive by topic.</p><div class="row wrap gap-10 mt-24"><button class="btn btn--primary btn--sm" data-filter="all">All</button>{categories.map(c=><button class="btn btn--ghost btn--sm" data-filter={c}>{c}</button>)}</div></div><div class="cards-3" id="archive-grid">{posts.map(p=><ArticleCard title={p.data.title} description={p.data.description} href={`/posts/${p.slug}/`} image={p.data.heroImage} category={p.data.category} pubDate={p.data.pubDate} slug={p.slug}/>)}</div><script is:inline>const buttons=[...document.querySelectorAll('[data-filter]')],cards=[...document.querySelectorAll('#archive-grid article')];buttons.forEach(btn=>btn.addEventListener('click',()=>{const f=btn.dataset.filter;buttons.forEach(b=>b.className='btn btn--ghost btn--sm');btn.className='btn btn--primary btn--sm';cards.forEach(c=>{c.style.display=f==='all'||c.textContent.toLowerCase().includes(f.toLowerCase())?'':'none'})}))</script></section></BaseLayout>

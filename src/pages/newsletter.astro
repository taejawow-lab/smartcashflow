---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Newsletter" description="Join The Steady State, Smartcashflow's calm weekly money newsletter."><section class="hero-dark"><div class="container" style="position:relative;padding-block:clamp(52px,8vw,96px)"><div class="hero-grid"><div><div class="eyebrow eyebrow--cream" style="margin-bottom:18px">The Steady State · weekly</div><h1 class="display" style="color:var(--paper);font-size:clamp(2.2rem,5vw,3.6rem);max-width:15ch">One useful money idea, every Sunday.</h1><p class="lede" style="color:rgba(244,240,230,.8);margin-top:18px;max-width:46ch">No spam, no hype, no 30-link digests. Just one clear concept you can act on — plus a free starter kit when you join.</p></div><div class="card" style="padding:clamp(26px,3vw,36px)"><h2 class="h3">Get the starter kit</h2><p class="muted">Enter your email. If confirmation is enabled, check your inbox.</p><form data-scf-newsletter><label class="eyebrow no-rule" for="email">Email address</label><input class="field" id="email" name="email" type="email" placeholder="you@example.com" required style="margin-top:8px"/><button class="btn btn--primary btn--block mt-16" type="submit">Subscribe</button><p class="muted" data-scf-newsletter-status style="margin-top:12px"></p></form></div></div></div></section></BaseLayout>

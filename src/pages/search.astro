---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
const posts=(await getCollection('posts')).filter(p=>!p.data.draft).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf());
const searchIndex=posts.map(p=>({title:p.data.title,description:p.data.description,category:p.data.category||'general',tags:p.data.tags||[],url:`/posts/${p.slug}/`,date:p.data.pubDate?.toISOString?.().slice(0,10)||''}));
---
<BaseLayout title="Search" description="Search Smartcashflow guides."><section class="container section--tight"><div class="eyebrow">Search</div><h1 class="display" style="font-size:clamp(2.2rem,5vw,3.6rem);margin-top:12px">Search the desk</h1><input id="site-search" class="field mt-24" type="search" placeholder="emergency fund, insurance, roth..." autocomplete="off"/><p id="search-count" class="muted mt-12">Showing latest articles</p><div id="search-results" class="cards-3 mt-24" aria-live="polite"></div><script type="application/json" id="search-index" set:html={JSON.stringify(searchIndex)}/><script is:inline>const q=document.getElementById('site-search'),r=document.getElementById('search-results'),c=document.getElementById('search-count'),idx=JSON.parse(document.getElementById('search-index').textContent||'[]');function esc(s){return String(s||'').replace(/[&<>\"]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m]))}function render(items,term){if(!items.length){r.innerHTML=`<div class="card" style="padding:24px"><h2 class="h3">No matching articles yet.</h2><p class="card__excerpt" style="margin-top:8px">Try a broader topic, category, or planning term. ${esc(term)}</p></div>`}else{r.innerHTML=items.map(i=>`<a href="${esc(i.url)}" class="card card--link" style="padding:24px"><span class="tag tag--brass">${esc(i.category)}</span><h2 class="h3" style="margin-top:12px">${esc(i.title)}</h2><p class="card__excerpt" style="margin-top:8px">${esc(i.description)}</p><span class="link-arrow mt-16">Read guide →</span></a>`).join('')}c.textContent=term?`${items.length} matching articles`:'Showing latest articles'}function sync(term){const u=new URL(location.href);if(term)u.searchParams.set('q',term);else u.searchParams.delete('q');history.replaceState(null,'',u.pathname+u.search+u.hash)}function s(){const raw=String(q.value||'').trim(),term=raw.toLowerCase();sync(raw);if(!term)return render(idx.slice(0,12),'');const terms=term.split(/\s+/);render(idx.filter(i=>{const h=[i.title,i.description,i.category,...(i.tags||[])].join(' ').toLowerCase();return terms.every(t=>h.includes(t))}),raw)}const initial=new URLSearchParams(location.search).get('q')||'';if(initial)q.value=initial;q.addEventListener('input',s);s()</script></section></BaseLayout>

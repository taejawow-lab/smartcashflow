---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
export async function getStaticPaths(){const slugify=(s:string)=>s.toLowerCase().trim().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'');const posts=(await getCollection('posts')).filter(p=>!p.data.draft);const cats=[...new Set(posts.map(p=>p.data.category).filter(Boolean))];const base=cats.map(cat=>({params:{category:slugify(cat)},props:{category:cat,posts:posts.filter(p=>p.data.category===cat).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf())}}));const canon=[['personal-finance','Personal Finance'],['emergency-funds','Emergency Funds'],['insurance','Insurance'],['cash-flow','Cash Flow'],['retirement','Retirement']];
const existing=new Set(base.map(x=>x.params.category));
for (const [slug,name] of canon){ if(!existing.has(slug)){ const words=slug.split('-'); const matches=posts.filter(p=>{const h=[p.data.category,p.data.title,p.data.description,...(p.data.tags||[])].join(' ').toLowerCase(); return words.every(w=>h.includes(w)) || h.includes(name.toLowerCase());}).sort((a,b)=>b.data.pubDate.valueOf()-a.data.pubDate.valueOf()); base.push({params:{category:slug},props:{category:name,posts:matches}}); }}
return base;}
const {category,posts}=Astro.props; const lead=posts[0];
---
<BaseLayout title={`${category} Guides`} description={`Every ${category} guide on Smartcashflow.`}><section class="hero-dark"><div class="container" style="position:relative;padding-block:clamp(46px,7vw,88px)"><div class="eyebrow eyebrow--cream" style="margin-bottom:16px">Learning path</div><h1 class="display" style="color:var(--paper);font-size:clamp(2.2rem,5vw,3.6rem)">{category}</h1><p class="lede" style="color:rgba(244,240,230,.78);max-width:58ch;margin-top:14px">A curated track for one pillar of a steady financial life.</p></div></section><section class="container section--tight">{lead&&<div style="margin-bottom:34px"><div class="eyebrow" style="margin-bottom:12px">Start here</div><ArticleCard title={lead.data.title} description={lead.data.description} href={`/posts/${lead.slug}/`} image={lead.data.heroImage} category={lead.data.category} pubDate={lead.data.pubDate} variant="horizontal" slug={lead.slug}/></div>}<div class="cards-3">{posts.slice(1).map(p=><ArticleCard title={p.data.title} description={p.data.description} href={`/posts/${p.slug}/`} image={p.data.heroImage} category={p.data.category} pubDate={p.data.pubDate} slug={p.slug}/>)}</div></section></BaseLayout>

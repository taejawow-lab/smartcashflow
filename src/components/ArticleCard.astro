---
export interface Props { title:string; description:string; href:string; image?:string; category?:string; pubDate:Date; readingTime?:number; variant?:'feature'|'standard'|'horizontal'; slug?:string; }
const {title,description,href,image,category,pubDate,readingTime,variant='standard',slug=href.split('/').filter(Boolean).pop()}=Astro.props;
const dateline=pubDate?.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
---
<article class={`card card--link ${variant==='horizontal'?'md:flex-row':''}`} data-slug={slug}><a href={href} class="card__media" aria-label={title} style={variant==='horizontal'?'min-width:min(360px,100%);':''}>{image?<img src={image} alt={title} loading="lazy" decoding="async"/>:<div class="swatch"><div class="swatch__grid"></div><div class="swatch__mark"><svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 19V5"/><path d="M4 19h16"/><path d="m7 15 4-4 3 3 5-7"/></svg></div></div>}{category&&<span class="tag" style="position:absolute;top:14px;left:14px;background:rgba(244,240,230,.92)">{category}</span>}</a><div class="card__body"><h3 class="card__title"><a href={href}>{title}</a></h3><p class="card__excerpt">{description}</p><div class="card__foot"><span class="meta"><span>{dateline}</span><span class="sep"></span><span>{readingTime||7} min</span></span><button class="bm" type="button" aria-pressed="false" aria-label="Save for later" data-scf-bookmark={slug}><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4h12v17l-6-4-6 4z"/></svg></button></div></div></article>

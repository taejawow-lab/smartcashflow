---
// Affiliate-aware link component v4.
// v4: pauses Amazon outbound links unless PUBLIC_AMAZON_ASSOCIATES_ACTIVE=true.
// This prevents closed/unapproved Associates store IDs from publishing Amazon
// Special Links and allows re-enabling only after a fresh compliant approval.
//
// Usage:
//   <Aff href="https://amazon.com/dp/B07XXXXX" region="us">Buy</Aff>
//   <Aff href="https://amazon.com/dp/B07XXXXX" region="us" subtag="custom-id">Buy</Aff>

export interface Props {
  href: string;
  region?: 'us' | 'uk' | 'kr' | 'jp' | 'ca' | 'de' | 'fr' | 'it' | 'es' | 'in';
  subtag?: string;
  rel?: string;
  class?: string;
  target?: string;
}

const { href, region = 'us', subtag, rel = 'sponsored noopener nofollow', class: cls = '', target = '_blank' } = Astro.props;

const defaultTag = import.meta.env.PUBLIC_AMAZON_TAG as string | undefined;
const associatesActive = (import.meta.env.PUBLIC_AMAZON_ASSOCIATES_ACTIVE as string | undefined) === 'true';

const tagEnvMap: Record<string, string> = {
  us: 'PUBLIC_AMAZON_TAG_US',
  uk: 'PUBLIC_AMAZON_TAG_UK',
  kr: 'PUBLIC_AMAZON_TAG_KR',
  jp: 'PUBLIC_AMAZON_TAG_JP',
  ca: 'PUBLIC_AMAZON_TAG_CA',
  de: 'PUBLIC_AMAZON_TAG_DE',
  fr: 'PUBLIC_AMAZON_TAG_FR',
  it: 'PUBLIC_AMAZON_TAG_IT',
  es: 'PUBLIC_AMAZON_TAG_ES',
  in: 'PUBLIC_AMAZON_TAG_IN',
};

function pageBase(): { site: string; page: string; combined: string } {
  let host = '';
  let segment = 'home';
  try {
    const path = (Astro.url && Astro.url.pathname) ? Astro.url.pathname : '';
    segment = path.replace(/^\//, '').replace(/\/$/, '').split('/').pop() || 'home';
    if (Astro.site) {
      const u = new URL(Astro.site.toString());
      host = u.hostname.replace(/^www\./, '').split('.')[0];
    }
  } catch {}
  return {
    site: host || 'site',
    page: segment,
    combined: host ? `${host}-${segment}` : segment,
  };
}

function sanitizeSubtag(s: string): string {
  return s.replace(/[^a-zA-Z0-9._-]/g, '').slice(0, 80);
}

function isAmazonUrl(url: string): boolean {
  return /(^|\.)amazon\.|amzn\.to|amzn\.asia/i.test(url);
}

const base = pageBase();
const composedSubtag = subtag ? `${base.combined}-${subtag}` : base.combined;
const finalSubtag = sanitizeSubtag(composedSubtag);
const amazonUrl = isAmazonUrl(href);

function buildAffUrl(url: string, reg: string, asc: string): string {
  if (!isAmazonUrl(url)) return url;
  if (!associatesActive) return '';
  try {
    const u = new URL(url);
    // Legacy content used uppercase US and Global; normalize both to the US Associates marketplace.
    const normalizedRegion = reg.toLowerCase() === "global" ? "us" : reg.toLowerCase();
    const tagEnv = tagEnvMap[normalizedRegion];
    const tag = (tagEnv ? (import.meta.env[tagEnv] as string | undefined) : undefined) || defaultTag;
    if (!tag) return '';
    u.searchParams.set('tag', tag);
    if (asc) u.searchParams.set('ascsubtag', asc);
    return u.toString();
  } catch {
    return '';
  }
}

const finalHref = buildAffUrl(href, region, finalSubtag);
const productSubtag = subtag || '';
const disabled = amazonUrl && !finalHref;
const disabledClass = `${cls} opacity-60 cursor-not-allowed pointer-events-none`;
---

{disabled ? (
  <span
    class={disabledClass}
    role="text"
    aria-label="Amazon retailer link paused during Associates compliance review"
    data-aff="paused"
    data-aff-site={base.site}
    data-aff-page={base.page}
    data-aff-product={productSubtag}
    data-aff-region={region}
    data-aff-subtag={finalSubtag}
  >
    <slot />
  </span>
) : (
  <a
    href={finalHref}
    rel={rel}
    target={target}
    class={cls}
    data-aff="1"
    data-aff-site={base.site}
    data-aff-page={base.page}
    data-aff-product={productSubtag}
    data-aff-region={region}
    data-aff-subtag={finalSubtag}
  >
    <slot />
  </a>
)}

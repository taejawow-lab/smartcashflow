---
import LogoMark from './LogoMark.astro';
const navItems=[{label:'Guides',href:'/posts/'},{label:'Tools',href:'/tools/'},{label:'Newsletter',href:'/newsletter/'},{label:'About',href:'/about/'}];
---
<header class="site-header"><div class="container site-header__bar"><a href="/" class="brand" aria-label="Smartcashflow home"><LogoMark size={42}/><span class="brand__word">Smart<b>cashflow</b></span></a><nav class="nav" aria-label="Primary navigation">{navItems.map(i=><a href={i.href}>{i.label}</a>)}</nav><div class="header-actions"><a href="/search/" class="icon-btn" aria-label="Search"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg></a><a href="/saved/" class="icon-btn" aria-label="Saved articles"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4h12v17l-6-4-6 4z"/></svg><span class="badge" data-scf-saved-count hidden>0</span></a><a href="/newsletter/" class="btn btn--primary btn--sm">Subscribe</a><button class="icon-btn menu-toggle" type="button" aria-label="Open menu" data-scf-menu-open><svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M4 12h16M4 17h16"/></svg></button></div></div><div class="drawer-backdrop" data-scf-drawer-backdrop></div><aside class="drawer" data-scf-drawer aria-hidden="true"><div class="drawer__head"><a href="/" class="brand"><LogoMark size={38}/><span class="brand__word">Smart<b>cashflow</b></span></a><button class="icon-btn" type="button" aria-label="Close menu" data-scf-menu-close><svg width="21" height="21" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 6l12 12M18 6 6 18"/></svg></button></div><nav class="drawer__nav">{navItems.map(i=><a href={i.href}>{i.label}</a>)}<a href="/search/">Search</a><a href="/saved/">Saved <span data-scf-saved-count-text></span></a></nav><div class="drawer__cta"><a href="/newsletter/" class="btn btn--primary btn--block">Subscribe — it's free</a><a href="/tools/" class="btn btn--ghost btn--block">Open the toolkit</a></div></aside><script is:inline src="/assets/scf-app.js"></script></header>

---
import BaseLayout from './BaseLayout.astro';
import References from '../components/References.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
export interface Props{title:string;description:string;pubDate:Date;updatedDate?:Date;heroImage?:string;tags?:string[];category?:string;sources?:Array<{title:string;url:string;author?:string;year?:string}>;affiliate?:boolean;headings?:Array<{depth:number;slug:string;text:string}>;}
const {title,description,pubDate,updatedDate,heroImage,tags=[],category,sources=[],affiliate=false,headings=[]}=Astro.props;const categorySlug=category?category.toLowerCase().trim().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,''):'';const slug=Astro.url.pathname.split('/').filter(Boolean).pop();const readMin=7;
---
<BaseLayout title={title} description={description} image={heroImage} type="article" publishedTime={pubDate?.toISOString()} modifiedTime={(updatedDate||pubDate)?.toISOString()}><div class="reading-progress" data-reading-progress></div><article><header class="container container--narrow section--tight center">{category&&<a href={`/category/${categorySlug}/`} class="tag tag--brass">{category}</a>}<h1 class="display" style="font-size:clamp(2.2rem,5vw,3.6rem);margin-top:18px">{title}</h1><p class="lede" style="margin:18px auto 0;max-width:60ch">{description}</p><div class="row wrap gap-10" style="justify-content:center;margin-top:24px"><span class="meta">Published {pubDate?.toLocaleDateString('en-US')}</span><span class="sep"></span><span class="meta">⏱ {readMin} min read</span><button class="bm" type="button" data-scf-bookmark={slug} aria-pressed="false" aria-label="Save article"><svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 4h12v17l-6-4-6 4z"/></svg></button><button class="bm" type="button" data-scf-share aria-label="Share article"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m13 5 7 7-7 7"/></svg></button></div></header>{heroImage&&<div class="container"><img src={heroImage} alt={title} width="1280" height="720" loading="eager" decoding="async" style="width:100%;max-width:1050px;margin:0 auto 42px;border-radius:var(--r-xl);box-shadow:var(--shadow-lg);aspect-ratio:16/8;object-fit:cover;border:1px solid var(--line)"/></div>}<div class="container article-shell"><div class="prose-article">{affiliate&&<AffiliateDisclosure/>}<slot/><div class="card" style="padding:24px;margin-top:36px;background:var(--green-900);color:var(--paper)"><div class="eyebrow eyebrow--cream">Make it practical</div><h2 class="h3" style="color:var(--paper);margin-top:10px">Run the matching calculator</h2><p style="color:rgba(244,240,230,.75)">Turn this guide into a number you can use. Inputs stay in your browser.</p><a href="/tools/" class="btn btn--brass">Open the toolkit</a></div>{sources.length>0&&<References sources={sources}/>}</div>{headings.length>0&&<aside class="toc-card"><div class="eyebrow no-rule" style="margin-bottom:10px">In this guide</div>{headings.filter(h=>h.depth<=3).slice(0,8).map(h=><a href={`#${h.slug}`}>{h.text}</a>)}</aside>}</div>{tags.length>0&&<footer class="container container--narrow" style="margin-top:42px;padding-top:28px;border-top:1px solid var(--line)"><div class="row wrap gap-8">{tags.map(tag=><span class="tag tag--ghost">#{tag}</span>)}</div></footer>}</article></BaseLayout>
